&CONTROL
  calculation = 'md'
  prefix = 'pw'
  outdir = './out'
  pseudo_dir = '../../pseudo'
  verbosity = 'high'
  tprnfor = .true.
  dt = 10.0
  nstep = 4000
/
&SYSTEM
  ibrav = 4
  celldm(1) = 9.45271759
  celldm(3) = 1.97914393
  nat = 22
  ntyp = 4
  nbnd = 85
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.02
  nspin = 2
  starting_magnetization(1) = 0.3
/
&ELECTRONS
  conv_thr = 1.0d-6
  mixing_beta = 0.3
  mixing_mode = 'local-TF'
  electron_maxstep = 300
/
&IONS
  ion_dynamics = 'verlet'
  ion_temperature = 'svr'
  tempw = 290.0
/
ATOMIC_SPECIES
  Co  58.93300  Co.pbe-spn-kjpaw_psl.0.3.1.UPF
  O  15.99900  O.pbe-n-kjpaw_psl.1.0.0.UPF
  Na  22.98977  Na.pbe-spn-kjpaw_psl.1.0.0.UPF
  H  1.00800  H.pbe-kjpaw_psl.1.0.0.UPF
! Set L (cage-ensemble MD, jobs_ensemble/md_cage): Born-Oppenheimer MD
! of the set-G hydrate ansatz (see G_NOTES in generate_inputs.py) at
! Na delta = 0 (z = c/2). ONLY the 12 water atoms move: if_pos = 0 0 0
! on every Co, framework O, and Na atom; 1 1 1 on water O and H (same
! atom ordering/mask as set J's IF_POS_J_PINNED). ion_dynamics =
! 'verlet', ion_temperature = 'svr', tempw = 290 K, dt = 10 Ry a.u.
! (~0.48 fs), nstep = 4000 (~1.9 ps). K_POINTS coarsened to 3 3 1 and
! conv_thr loosened to 1e-6 purely for MD throughput -- NOT used for
! the set-M snapshot SCFs, which revert to the exact set-G electronic
! settings (K_POINTS 6 6 2, conv_thr 1e-7) for comparability.
! Purpose: sample a thermal ensemble of cage configurations at 290 K;
! set M (generated pod-side by make_ensemble_scans.py after this MD
! finishes) freezes 10 snapshots (first 1000 steps discarded as
! equilibration) and rigidly scans Na through delta = +/-0.45..0.00 A
! at each -- the ensemble of resulting E(delta) curves is the physical
! (statistical, non-adiabatic) counterpart to the set-G rigid-cage and
! set-J single-adiabatic-minimum curves.
ATOMIC_POSITIONS crystal
  Co  0.0000000000  0.0000000000  0.0000000000  0 0 0
  Co  0.3333333333  0.6666666667  0.0000000000  0 0 0
  Co  0.6666666667  0.3333333333  0.0000000000  0 0 0
  O  0.3333333333  0.3333333333  0.0969696970  0 0 0
  O  0.6666666667  0.0000000000  0.0969696970  0 0 0
  O  0.0000000000  0.6666666667  0.0969696970  0 0 0
  O  0.3333333333  0.0000000000  0.9030303030  0 0 0
  O  0.6666666667  0.6666666667  0.9030303030  0 0 0
  O  0.0000000000  0.3333333333  0.9030303030  0 0 0
  Na  0.0000000000  0.0000000000  0.5000000000  0 0 0
  O  0.3333333333  0.0000000000  0.3787878788  1 1 1
  H  0.5340199106  0.0303423465  0.3984293317  1 1 1
  H  0.3120938818  0.9696576535  0.2830660485  1 1 1
  O  0.0000000000  0.3333333333  0.3787878788  1 1 1
  H  0.9696576535  0.5036775641  0.3984293317  1 1 1
  H  0.0303423465  0.3424362283  0.2830660485  1 1 1
  O  0.3333333333  0.6666666667  0.6212121212  1 1 1
  H  0.3581077436  0.8675400977  0.6085279256  1 1 1
  H  0.4121627694  0.6730009283  0.7099766943  1 1 1
  O  0.6666666667  0.3333333333  0.6212121212  1 1 1
  H  0.8675400977  0.5094323541  0.6085279256  1 1 1
  H  0.6730009283  0.2608381589  0.7099766943  1 1 1
K_POINTS automatic
  3 3 1 0 0 0

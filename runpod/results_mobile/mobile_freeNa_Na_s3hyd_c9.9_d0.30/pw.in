&CONTROL
  calculation = 'relax'
  prefix = 'pw'
  outdir = './out'
  pseudo_dir = '../../pseudo'
  verbosity = 'high'
  tprnfor = .true.
  forc_conv_thr = 1.0d-3
  nstep = 100
/
&SYSTEM
  ibrav = 4
  celldm(1) = 9.45271759
  celldm(3) = 1.97914393
  nat = 22
  ntyp = 4
  nbnd = 85
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.02
  nspin = 2
  starting_magnetization(1) = 0.3
/
&ELECTRONS
  conv_thr = 1.0d-7
  mixing_beta = 0.3
  mixing_mode = 'local-TF'
  electron_maxstep = 300
/
&IONS
  ion_dynamics = 'bfgs'
/
ATOMIC_SPECIES
  Co  58.93300  Co.pbe-spn-kjpaw_psl.0.3.1.UPF
  O  15.99900  O.pbe-n-kjpaw_psl.1.0.0.UPF
  Na  22.98977  Na.pbe-spn-kjpaw_psl.1.0.0.UPF
  H  1.00800  H.pbe-kjpaw_psl.1.0.0.UPF
! Set J3 (joint-minimum search): same hydrate relax as the set J1
! delta = 0.30 job (waters free, CoO2 frozen), but Na z is ALSO free
! (if_pos 0 0 1; x,y pinned to the Co-top column), starting
! off-center at delta = 0.30 A.  Tests whether the JOINT (Na + water)
! minimum is off-center at all: if Na slides back to z = c/2 the
! adiabatic well is not merely flattened but centered.
